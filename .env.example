# HTTP Server configurations
PORT=3000

# LLM Provider selection ('openai' or 'llamacpp')
LLM_PROVIDER=openai

# OpenAI API Key (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Local Llama.cpp configurations (used when LLM_PROVIDER=llamacpp)
LLAMACPP_URL=http://localhost:8080
LLAMACPP_MODEL=local-model

# Ticket queue storage
DB_PATH=./data/database.sqlite

# Direct remote knowledge providers
VALORANT_WIKI_API_URL=https://wiki.playvalorant.com/en-us/api.php
HUGGINGFACE_DATASET_API_URL=https://datasets-server.huggingface.co
GENZ_SLANG_DATASET=MLBtrio/genz-slang-dataset
REMOTE_CONTENT_CACHE_TTL_MS=86400000
REMOTE_REQUEST_TIMEOUT_MS=30000
