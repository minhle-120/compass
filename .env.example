# HTTP Server configurations
PORT=3000

# LLM Provider selection ('openai' or 'llamacpp')
LLM_PROVIDER=openai

# OpenAI API Key (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Local Llama.cpp configurations (used when LLM_PROVIDER=llamacpp)
LLAMACPP_URL=http://localhost:8080
LLAMACPP_MODEL=local-model

# SQLite database storage locations
DB_PATH=./data/database.sqlite
GAME_KNOWLEDGE_DB_PATH="./data/Game Knowledge Base.sqlite"
SLANG_DB_PATH=./data/slang.sqlite

# Valorant Wiki knowledge-base synchronization
VALORANT_WIKI_API_URL=https://wiki.playvalorant.com/en-us/api.php
VALORANT_WIKI_SYNC_ENABLED=true
VALORANT_WIKI_SYNC_INTERVAL_MS=86400000
VALORANT_WIKI_REQUEST_TIMEOUT_MS=30000
VALORANT_WIKI_BATCH_SIZE=20
