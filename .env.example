# HTTP Server configurations
PORT=3000

# LLM Provider selection ('openai' or 'llamacpp')
LLM_PROVIDER=openai

# OpenAI API Key (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Local Llama.cpp configurations (used when LLM_PROVIDER=llamacpp)
LLAMACPP_URL=http://localhost:8080
LLAMACPP_MODEL=local-model

# Ticket queue storage
DB_PATH=./data/database.sqlite

# Editable local game knowledge wiki
WIKI_DB_PATH=./data/wiki.sqlite

# Incident service database storage location
INCIDENT_DB_PATH=./data/incidents.sqlite

# Valorant Wiki import source (runtime searches use the local wiki)
VALORANT_WIKI_API_URL=https://wiki.playvalorant.com/en-us/api.php
VALORANT_API_URL=https://valorant-api.com
VALORANT_WIKI_TERMINOLOGY_PAGE=Terminology
WIKI_SYNC_INTERVAL_MS=86400000

# Editable local slang wiki
SLANG_DB_PATH=./data/slang.sqlite

# Direct slang providers
HUGGINGFACE_DATASET_API_URL=https://datasets-server.huggingface.co
GENZ_SLANG_DATASET=MLBtrio/genz-slang-dataset
URBAN_DICTIONARY_API_URL=https://api.urbandictionary.com/v0/define
REMOTE_CONTENT_CACHE_TTL_MS=86400000
REMOTE_REQUEST_TIMEOUT_MS=30000
