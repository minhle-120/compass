{
  "name": "p12-support-agent",
  "version": "1.0.0",
  "description": "Standalone thread-isolated support agent loop with local database adapters",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "wiki:import": "node scripts/import-wiki-snapshot.js",
    "wiki:catalog": "node scripts/build-wiki-catalog.js",
    "wiki:refresh": "node scripts/refresh-wiki.js",
    "wiki:terminology-refresh": "node scripts/import-valorant-wiki.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "1.18.1",
    "better-sqlite3": "12.11.1",
    "dotenv": "17.4.2",
    "express": "5.2.1"
  },
  "devDependencies": {
    "vitest": "4.1.10"
  }
}
